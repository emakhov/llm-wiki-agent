# LLM Provider: "openrouter", "claude" or "openai"
LLM_PROVIDER=openrouter

# Model ID override (optional — defaults to claude-sonnet-4-20250514 or gpt-4o)
LLM_MODEL=

# API Keys
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# PostgreSQL connection
DATABASE_URL=

# Langfuse configuration
LANGFUSE_ENABLED=false

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=